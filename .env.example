# =============================================
# FOCUS RP - Whitelist Bot Konfigurasjon
# Kopier denne filen til .env og fyll ut verdiene
# =============================================

# Discord Bot Token (fra Discord Developer Portal)
DISCORD_TOKEN=

# ID til serveren din
GUILD_ID=

# ID til kanalen der søknadsknappen skal ligge (f.eks. #søknad)
APPLICATION_CHANNEL_ID=

# ID til kanalen der staff ser innkomne søknader
STAFF_CHANNEL_ID=

# ID til rollen som gis ved godkjennelse (Whitelisted-rollen)
WHITELISTED_ROLE_ID=

# Minimum alder for å søke
MIN_AGE=16

# Timeout for søknad i minutter (hvor lenge bot venter på svar)
APPLICATION_TIMEOUT_MINUTES=30
